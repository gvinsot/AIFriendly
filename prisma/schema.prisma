generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_CONNECTION_STRING")
}

// ─── NextAuth.js models ──────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?
  stripePriceId         String?
  stripeCurrentPeriodEnd DateTime?
  accounts              Account[]
  sessions              Session[]
  sites                 Site[]
  apiKeys               ApiKey[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── MCP API Keys ────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  keyPrefix  String    // First 8 chars for display (e.g., "afk_ab12…")
  lastUsedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// ─── Application models ──────────────────────────────────────────────────────

model Site {
  id                  String              @id @default(cuid())
  userId              String
  name                String
  url                 String
  frequency           String              @default("daily") // "6h" | "daily" | "weekly" | "monthly"
  isActive            Boolean             @default(true)
  availabilityEnabled Boolean             @default(true)
  securityEnabled     Boolean             @default(true)
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses            AnalysisResult[]
  availabilityChecks  AvailabilityCheck[]
  securityScans       SecurityScan[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([userId])
}

model AnalysisResult {
  id               String   @id @default(cuid())
  siteId           String
  score            Float
  maxScore         Float    @default(10)
  ethicsScore      Float?
  coherenceScore   Float?
  aiGeneratedScore Float?
  details          Json
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@index([siteId, createdAt])
  @@index([createdAt])
}

model AvailabilityCheck {
  id           String    @id @default(cuid())
  siteId       String
  score        Float
  httpStatus   Int?
  pingMs       Float?
  ttfbMs       Float?
  loadTimeMs   Float?
  responseSize Int?
  sslValid     Boolean?
  sslExpiry    DateTime?
  details      Json
  site         Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([siteId, createdAt])
  @@index([createdAt])
}

model SecurityScan {
  id             String   @id @default(cuid())
  siteId         String
  score          Float
  headersScore   Float    @default(10)
  sslScore       Float    @default(10)
  cookiesScore   Float    @default(10)
  infoLeakScore  Float    @default(10)
  injectionScore Float    @default(10)
  details        Json
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([siteId, createdAt])
  @@index([createdAt])
}
