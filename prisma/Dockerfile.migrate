# AI Friendly — Prisma Migration Runner
# Runs `prisma migrate deploy` then exits
# Used for Docker Swarm deployments

FROM node:20-alpine

WORKDIR /app

# Install Prisma CLI
RUN npm install -g prisma@6

# Copy Prisma schema
COPY schema.prisma ./prisma/schema.prisma

# Copy migrations if they exist (use . to avoid failure if missing)
COPY migration[s] ./prisma/migrations

WORKDIR /app/prisma

# Run migrations and exit
CMD ["prisma", "migrate", "deploy"]
