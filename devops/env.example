# Copier en .env et adapter les valeurs.
# Host Traefik pour le routeur (sans https://)
# Le serveur MCP sera accessible sur mcp.<TRAEFIK_HOST> (ex: mcp.aifriendly.eu)
TRAEFIK_HOST=aifriendly.eu

# Optionnel : préfixe de l'image (registry)
# IMAGE_REGISTRY=registry.methodinfo.fr

# Base de données PostgreSQL
DB_CONNECTION_STRING=postgresql://user:password@host:5432/aifriendly

# NextAuth.js — Authentification OAuth
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://aifriendly.eu

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth — Personal accounts (https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for the 10€/month subscription (create in Stripe Dashboard → Products)
STRIPE_PRICE_ID=
